#!/usr/bin/env bash
# azorean-engine — CLI wrapper for the Azorean Stacks Engine service

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "$SOURCE_PATH" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done

ENGINE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
PLIST_NAME="com.azorean.stacks-engine"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"
LOG_FILE="$HOME/.openclaw/logs/azorean-engine.log"
STATUS_FILE="$HOME/.openclaw/data/azorean-engine-status.json"
RUNNER_PATH="$ENGINE_DIR/runner.sh"

install_plist() {
  mkdir -p "$(dirname "$PLIST_DST")"
  cat > "$PLIST_DST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$PLIST_NAME</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>$RUNNER_PATH</string>
    </array>

    <key>WorkingDirectory</key>
    <string>$ENGINE_DIR</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>$LOG_FILE</string>

    <key>StandardErrorPath</key>
    <string>$LOG_FILE</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
EOF
}

launchctl_pid() {
  launchctl list | awk -v label="$PLIST_NAME" '$3 == label { print $1 }'
}

status_running_flag() {
  [ -f "$STATUS_FILE" ] || return 0
  awk -F': ' '/"running"/ { gsub(/[ ,]/, "", $2); print $2 }' "$STATUS_FILE"
}

cmd_start() {
  install_plist
  launchctl unload "$PLIST_DST" 2>/dev/null || true
  launchctl load "$PLIST_DST" 2>/dev/null
  echo "Azorean Stacks Engine started."
}

cmd_stop() {
  launchctl unload "$PLIST_DST" 2>/dev/null
  echo "Azorean Stacks Engine stopped."
}

cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

cmd_status() {
  local pid=""
  local running_flag=""

  echo "=== Azorean Stacks Engine ==="
  echo ""

  pid="$(launchctl_pid)"
  running_flag="$(status_running_flag)"

  if [[ "$pid" =~ ^[0-9]+$ ]] && [ "$pid" -gt 0 ]; then
    echo "Status: RUNNING"
    echo "PID: $pid"
  elif launchctl list "$PLIST_NAME" &>/dev/null; then
    if [ "$running_flag" = "false" ]; then
      echo "Status: STOPPED"
      echo "Loaded agent is present, but the runner is not active."
    else
      echo "Status: LOADED"
      echo "Agent is loaded, but no active runner PID was reported."
    fi
  else
    echo "Status: STOPPED"
  fi

  echo ""

  # Show status file if it exists
  if [ -f "$STATUS_FILE" ]; then
    echo "--- Engine Status ---"
    cat "$STATUS_FILE"
    echo ""
  fi

  # Show last few log lines
  if [ -f "$LOG_FILE" ]; then
    echo "--- Recent Logs ---"
    tail -n 10 "$LOG_FILE"
  fi
}

cmd_logs() {
  local lines=""
  local follow=true

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -n)
        lines="$2"
        follow=false
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done

  if [ ! -f "$LOG_FILE" ]; then
    echo "No log file found at $LOG_FILE"
    exit 1
  fi

  if [ "$follow" = true ]; then
    tail -f "$LOG_FILE"
  else
    tail -n "${lines:-50}" "$LOG_FILE"
  fi
}

case "${1:-}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    shift; cmd_logs "$@" ;;
  *)
    echo "Usage: azorean-engine {start|stop|restart|status|logs [-n N]}"
    exit 1
    ;;
esac
